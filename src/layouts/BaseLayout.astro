---
import '../styles/global.css';
import GlobalSearch from '../components/GlobalSearch.svelte';
import { getAllEntries } from '../lib/entries';
import type { NavTarget } from '../lib/search';
import { buildNewEntryUrl, site } from '../site';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'browse' | 'functions' | 'snippets' | 'write-ups' | null;
}

const {
  title,
  description = 'Community-run synesthesia functions, snippets, and write-ups.',
  activeNav = null
} = Astro.props;

// Preloaded once per page so the global search overlay works everywhere.
const entries = await getAllEntries();

// Navigable destinations surfaced in search alongside content entries.
const searchPages: NavTarget[] = [
  { title: 'Home', href: '/', hint: 'Featured and recent submissions', keywords: ['home', 'featured', 'recent', 'start'] },
  { title: 'Functions', href: '/functions', hint: 'Reusable helper functions', keywords: ['functions', 'glsl', 'helpers'] },
  { title: 'Snippets', href: '/snippets', hint: 'Code drops and small recipes', keywords: ['snippets', 'recipes', 'code'] },
  { title: 'Write-ups', href: '/write-ups', hint: 'Guides, tutorials, and tips', keywords: ['write-ups', 'writeups', 'guides', 'tutorials', 'tips'] },
  { title: 'Submit via PR', href: buildNewEntryUrl(), hint: 'Contribute a new entry on GitHub', keywords: ['submit', 'contribute', 'pr', 'pull request', 'add', 'new'], external: true }
];

const nav = [
  { href: '/browse', label: 'browse', key: 'browse' },
  { href: '/functions', label: 'functions', key: 'functions' },
  { href: '/snippets', label: 'snippets', key: 'snippets' },
  { href: '/write-ups', label: 'write-ups', key: 'write-ups' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/" aria-label={site.name}>
          <span class="brand-mark">SF</span>
          <span class="brand-name">syn<span class="brand-name__dot">.</span>fun</span>
        </a>

        <nav class="topnav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={item.key === activeNav ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>

        <div class="topbar-actions">
          <button class="button js-open-search" type="button" aria-label="Search">
            <span class="search-form__icon">⌕</span>
            search
            <span class="search-form__key">?</span>
          </button>
          <a class="button button-primary" href={buildNewEntryUrl()} target="_blank" rel="noreferrer">Submit via PR ↗</a>
          <a class="button" href={site.repoUrl} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </div>
    </header>

    <main class="page-root">
        <slot />
    </main>

    <GlobalSearch client:load entries={entries} pages={searchPages} />

    <script>
      // Any element tagged .js-open-search opens the global search overlay.
      // The "?" shortcut itself is handled inside the GlobalSearch island.
      document.querySelectorAll('.js-open-search').forEach((el) => {
        el.addEventListener('click', () => {
          window.dispatchEvent(new CustomEvent('open-search'));
        });
      });
    </script>
  </body>
</html>

